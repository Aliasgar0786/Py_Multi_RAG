# Shopcard AI Chat Service - Environment Configuration

# Required: Your Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# LLM Provider: "gemini" (default) or "stub" (offline, no API calls)
LLM_PROVIDER=stub

# Optional: Gemini model to use (default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# Optional: WebSocket server port (default: 8080)
WS_PORT=8080
